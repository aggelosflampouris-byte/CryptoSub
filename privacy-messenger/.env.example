# Server
LISTEN_ADDR=:8443

# Postgres (metadata: users, devices, groups — never message content)
POSTGRES_DSN=postgres://messenger:messenger_dev@localhost:5432/messenger?sslmode=disable

# Redis (offline ciphertext queue, short TTL)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Cassandra (durable ciphertext backstop)
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=messenger

# Phone-hash pepper — MUST be a strong random secret in production.
# Changing this invalidates all existing user lookups.
PHONE_HASH_PEPPER=change-me-to-a-random-secret

# SMS provider (Twilio)
SMS_PROVIDER_API_KEY=your-twilio-account-sid
SMS_PROVIDER_SECRET=your-twilio-auth-token
SMS_FROM_NUMBER=+1234567890

# Object storage for encrypted media blobs
MEDIA_BUCKET=your-media-bucket
MEDIA_REGION=auto
MEDIA_ACCESS_KEY=your-access-key
MEDIA_SECRET_KEY=your-secret-key

# Push notifications (optional in dev)
# FCM_CREDENTIALS_PATH=/path/to/fcm-credentials.json
# APNS_KEY_PATH=/path/to/apns-key.p8
# APNS_KEY_ID=
# APNS_TEAM_ID=

# Tuning (optional, shown with defaults)
# OFFLINE_MESSAGE_TTL_SECONDS=1209600   # 14 days
# SESSION_TTL_SECONDS=2592000           # 30 days
