{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability granting the renderer access to standard Tauri APIs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:default",
    "notification:allow-notify",
    "os:default",
    "window-state:default"
  ]
}
