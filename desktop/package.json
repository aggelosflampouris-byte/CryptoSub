{
  "name": "cryptosub-desktop",
  "version": "0.2.0",
  "description": "CryptoSub — Secure E2E Encrypted Messenger for Windows",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xmtp/xmtp-js": "^11.3.17",
    "ethers": "^5.7.2",
    "qrcode": "^1.5.3",
    "qr-scanner": "^1.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.3.4",
    "vite-plugin-node-polyfills": "^0.22.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.privatemessenger.cryptosub",
    "productName": "CryptoSub",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
